#!/usr/bin/env bash
# Launch Aider routed to NVIDIA Qwen3-Next 80B via local LiteLLM proxy.
# Use for: routine coding, HTML/CSS, scripts, small fixes, exploration.
set -euo pipefail

INSTALL_DIR="${LITELLM_INSTALL_DIR:-$HOME/litellm-proxy}"

if [[ ! -f "$INSTALL_DIR/env.sh" ]]; then
  echo "error: $INSTALL_DIR/env.sh not found. Did you run install.sh?"
  exit 1
fi
# shellcheck disable=SC1091
source "$INSTALL_DIR/env.sh"
PROXY_URL="http://127.0.0.1:${LITELLM_PORT:-4000}"

if ! curl -fsS --max-time 2 "$PROXY_URL/health/liveness" >/dev/null 2>&1; then
  echo "litellm proxy not reachable. starting it..."
  "$INSTALL_DIR/start.sh"
  for _ in 1 2 3 4 5 6 7 8; do
    sleep 1
    curl -fsS --max-time 2 "$PROXY_URL/health/liveness" >/dev/null 2>&1 && break
  done
fi

if ! command -v aider >/dev/null 2>&1; then
  echo "error: aider not in PATH. install with: pip install --user aider-chat"
  exit 1
fi

export OPENAI_API_BASE="$PROXY_URL"
export OPENAI_API_KEY="$LITELLM_MASTER_KEY"

echo "→ Aider → LiteLLM → NVIDIA Qwen3-Next 80B (fast)"
exec aider --model openai/qwen3-next "$@"
